+mockSerializer := new(mocks.MockSerializer)
+mockSerializer.On("RenderDocument", mock.Anything, "opencode").
+    Return("---\ncontent\n---", nil)
+
+output, err := mockSerializer.RenderDocument(doc, "opencode")
+```
+
+---
