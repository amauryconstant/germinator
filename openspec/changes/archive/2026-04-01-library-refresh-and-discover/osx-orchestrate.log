package library_test

import (
    "fmt"
    "os"
    "path/filepath"
    "testing"
    
    "gitlab.com/amoconst/germinator/internal/infrastructure/library"
)

func TestDebugRefresh(t *testing.T) {
    tmpDir := t.TempDir()
    
    // Write library.yaml
    libraryYAML := `version: "1"
resources:
  skill:
    commit:
      path: skills/old.md
      description: old description
`
    os.WriteFile(filepath.Join(tmpDir, "library.yaml"), []byte(libraryYAML), 0644)
    
    // Create skills directory and file
    os.MkdirAll(filepath.Join(tmpDir, "skills"), 0755)
    content := `---
name: commit
description: new description
---
# Commit
`
    os.WriteFile(filepath.Join(tmpDir, "skills", "commit.md"), []byte(content), 0644)
    
    // Debug: check if files exist
    t.Logf("tmpDir: %s", tmpDir)
    t.Logf("library.yaml exists: %v", exists(filepath.Join(tmpDir, "library.yaml")))
    t.Logf("skills/commit.md exists: %v", exists(filepath.Join(tmpDir, "skills", "commit.md")))
    t.Logf("skills/old.md exists: %v", exists(filepath.Join(tmpDir, "skills", "old.md")))
    
    // Try loading library
    lib, err := library.LoadLibrary(tmpDir)
    if err != nil {
        t.Fatalf("Error loading: %v", err)
    }
    t.Logf("Library loaded, RootPath: %s", lib.RootPath)
    
    // Check resources
    for typ, resources := range lib.Resources {
        t.Logf("Type: %s", typ)
        for name, res := range resources {
            t.Logf("  Name: %s, Path: %s, Desc: %s", name, res.Path, res.Description)
            filePath := filepath.Join(lib.RootPath, res.Path)
            t.Logf("    Full path: %s, exists: %v", filePath, exists(filePath))
        }
    }
    
    // Try refresh
    result, err := library.RefreshLibrary(library.RefreshOptions{
        LibraryPath: tmpDir,
        DryRun: false,
        Force: false,
    })
    if err != nil {
        t.Fatalf("Error refreshing: %v", err)
    }
    t.Logf("Refreshed: %d, Skipped: %d, Errors: %d", len(result.Refreshed), len(result.Skipped), len(result.Errors))
    for _, r := range result.Refreshed {
        t.Logf("  Refreshed: %+v", r)
    }
    for _, s := range result.Skipped {
        t.Logf("  Skipped: %+v", s)
    }
    for _, e := range result.Errors {
        t.Logf("  Error: %+v", e)
    }
}

func exists(path string) bool {
    _, err := os.Stat(path)
    return err == nil
}
