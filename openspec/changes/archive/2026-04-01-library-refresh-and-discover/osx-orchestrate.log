)

func main() {
    tmpDir := "/tmp/germ-debug"
    os.RemoveAll(tmpDir)
    os.MkdirAll(tmpDir, 0755)
    
    // Write library.yaml
    libraryYAML := `version: "1"
resources:
  skill:
    commit:
      path: skills/old.md
      description: old description
`
    os.WriteFile(filepath.Join(tmpDir, "library.yaml"), []byte(libraryYAML), 0644)
    
    // Create skills directory and file
    os.MkdirAll(filepath.Join(tmpDir, "skills"), 0755)
    content := `---
name: commit
description: new description
---
# Commit
`
    os.WriteFile(filepath.Join(tmpDir, "skills", "commit.md"), []byte(content), 0644)
    
    // Debug: check if files exist
    fmt.Println("=== File check ===")
    fmt.Println("library.yaml exists:", exists(filepath.Join(tmpDir, "library.yaml")))
    fmt.Println("skills/commit.md exists:", exists(filepath.Join(tmpDir, "skills", "commit.md")))
    fmt.Println("skills/old.md exists:", exists(filepath.Join(tmpDir, "skills", "old.md")))
    
    // Try loading library
    fmt.Println("\n=== Load library ===")
    lib, err := library.LoadLibrary(tmpDir)
    if err != nil {
        fmt.Println("Error loading:", err)
        return
    }
    fmt.Printf("Library loaded: %+v\n", lib)
    
    // Check resources
    fmt.Println("\n=== Resources ===")
    for typ, resources := range lib.Resources {
        fmt.Printf("Type: %s\n", typ)
        for name, res := range resources {
            fmt.Printf("  Name: %s, Path: %s, Desc: %s\n", name, res.Path, res.Description)
        }
    }
    
    // Try refresh
    fmt.Println("\n=== Refresh ===")
    result, err := library.RefreshLibrary(library.RefreshOptions{
        LibraryPath: tmpDir,
        DryRun: false,
        Force: false,
    })
    if err != nil {
        fmt.Println("Error refreshing:", err)
        return
    }
    fmt.Printf("Refreshed: %d, Skipped: %d, Errors: %d\n", len(result.Refreshed), len(result.Skipped), len(result.Errors))
    for _, r := range result.Refreshed {
        fmt.Printf("  Refreshed: %+v\n", r)
    }
    for _, s := range result.Skipped {
        fmt.Printf("  Skipped: %+v\n", s)
    }
    for _, e := range result.Errors {
        fmt.Printf("  Error: %+v\n", e)
    }
}

func exists(path string) bool {
    _, err := os.Stat(path)
    return err == nil
}
