 // extractNameFromFilename extracts a resource name from filename.
 // E.g., "agent-reviewer.md" -> "reviewer", "skill-commit.md" -> "commit"
+// Returns empty string if no recognized pattern is found.
 func extractNameFromFilename(source string) string {
 	// Get base filename without extension
 	base := filepath.Base(source)
 	ext := filepath.Ext(base)
 	name := strings.TrimSuffix(base, ext)
 
-	// Remove prefix patterns like "agent-", "skill-", "command-", "memory-"
-	patterns := []string{
-		`^agent[-_]`,
-		`^skill[-_]`,
-		`^command[-_]`,
-		`^memory[-_]`,
-		`[-_]agent$`,
-		`[-_]skill$`,
-		`[-_]command$`,
-		`[-_]memory$`,
+	// Define prefix/suffix patterns
+	patterns := []struct {
+		pattern  string
+		isSuffix bool
+	}{
+		{`^agent[-_]`, false},
+		{`^skill[-_]`, false},
+		{`^command[-_]`, false},
+		{`^memory[-_]`, false},
+		{`[-_]agent$`, true},
+		{`[-_]skill$`, true},
+		{`[-_]command$`, true},
+		{`[-_]memory$`, true},
 	}
 
-	for _, pattern := range patterns {
-		re := regexp.MustCompile(pattern)
-		name = re.ReplaceAllString(name, "")
+	hadMatch := false
+	for _, p := range patterns {
+		re := regexp.MustCompile(p.pattern)
+		if re.MatchString(name) {
+			hadMatch = true
+			name = re.ReplaceAllString(name, "")
+		}
 	}
 
+	if !hadMatch {
+		return ""
+	}
+
 	return name
 }


