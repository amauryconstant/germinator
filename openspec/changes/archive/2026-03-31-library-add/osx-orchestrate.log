// Package library provides library management for canonical resources.
package library

import (
	"fmt"
	"os"
	"path/filepath"
	"regexp"
	"strings"

	gerrors "gitlab.com/amaconst/germinator/internal/domain"
	yaml "gopkg.in/yaml.v3"
)

// AddOptions contains options for adding a resource to the library.
type AddOptions struct {
	// Source is the path to the source file to add.
	Source string
	// Name is the resource name (optional - auto-detected if not provided).
	Name string
	// Description is the resource description (optional - auto-detected if not provided).
	Description string
	// Type is the resource type (optional - auto-detected if not provided).
	Type string
	// LibraryPath is the path to the library directory.
	LibraryPath string
	// DryRun indicates whether to preview without making changes.
	DryRun bool
	// Force overwrites existing resources.
	Force bool
}

// AddResource adds a resource from a source file to the library.
// The source file should already be in canonical format and validated.
// Canonicalization and validation are handled by the caller (typically cmd layer).
func AddResource(opts AddOptions) error {
	// Detect type, name, description if not provided
	resourceType := opts.Type
	if resourceType == "" {
		detected, err := detectType(opts.Source, "")
		if err != nil {
			return err
		}
		resourceType = detected
	}

	name := opts.Name
	if name == "" {
		detected, err := detectName(opts.Source, "")
		if err != nil {
			return err
		}
		name = detected
	}

	description := opts.Description
	if description == "" {
		detected, err := detectDescription(opts.Source, "")
		if err != nil {
			return err
		}
		description = detected
	}

	// Determine target path in library
	targetPath := filepath.Join(opts.LibraryPath, resourceType+"s", name+".md")

	// Load library to check for conflicts and get current state
	lib, err := LoadLibrary(opts.LibraryPath)
	if err != nil {
		return fmt.Errorf("loading library: %w", err)
	}

	// Check for existing resource
	ref := FormatRef(resourceType, name)
	if resources, ok := lib.Resources[resourceType]; ok {
		if _, exists := resources[name]; exists && !opts.Force {
			return gerrors.NewFileError(targetPath, "add", "resource already exists (use --force to overwrite)", nil)
		}
	}

	// Dry run mode - show what would happen
	if opts.DryRun {
		fmt.Printf("Would add resource: %s\n", ref)
		fmt.Printf("  Source: %s\n", opts.Source)
		fmt.Printf("  Target: %s\n", targetPath)
		fmt.Printf("  Description: %s\n", description)
		return nil
	}

	// Ensure target directory exists
	targetDir := filepath.Dir(targetPath)
	if err := os.MkdirAll(targetDir, 0750); err != nil {
		return gerrors.NewFileError(targetDir, "create", "failed to create directory", err)
	}

	// Copy source file to target
	content, err := os.ReadFile(opts.Source)
	if err != nil {
		return gerrors.NewFileError(opts.Source, "read", "failed to read source file", err)
	}
	if err := os.WriteFile(targetPath, content, 0644); err != nil {
		return gerrors.NewFileError(targetPath, "write", "failed to write file", err)
	}

	// Update library.yaml
	if err := addResourceToLibrary(opts.LibraryPath, resourceType, name, targetPath, description); err != nil {
		return err
	}

	// Validate library after update
	if _, err := LoadLibrary(opts.LibraryPath); err != nil {
		return fmt.Errorf("library validation failed after update: %w", err)
	}

	fmt.Printf("Added resource: %s\n", ref)
	return nil
}

// detectType detects the resource type from source file or flag.
// Priority: flag > frontmatter > filename pattern
func detectType(source, flag string) (string, error) {
	// Flag takes precedence
	if flag != "" {
		rt := ResourceType(flag)
		if !rt.IsValid() {
			validTypes := make([]string, len(ValidResourceTypes))
			for i, t := range ValidResourceTypes {
				validTypes[i] = string(t)
			}
			return "", gerrors.NewConfigError("type", flag, "invalid resource type").WithSuggestions(validTypes)
		}
		return flag, nil
	}

	// Try frontmatter
	frontmatterType, err := extractFrontmatterField(source, "type")
	if err == nil && frontmatterType != "" {
		rt := ResourceType(frontmatterType)
		if rt.IsValid() {
			return frontmatterType, nil
		}
	}

	// Try filename pattern using DetectTypeFromFilename
	detected := DetectTypeFromFilename(source)
	if detected != "" {
		return detected, nil
	}

	return "", gerrors.NewFileError(source, "detect", "could not detect resource type (use --type flag)", nil)
}

// detectName detects the resource name from source file or flag.
// Priority: flag > frontmatter > filename
func detectName(source, flag string) (string, error) {
	// Flag takes precedence
	if flag != "" {
		return flag, nil
	}

	// Try frontmatter
	name, err := extractFrontmatterField(source, "name")
	if err == nil && name != "" {
		return name, nil
	}

	// Try filename (e.g., "skill-commit.md" -> "commit")
	name = extractNameFromFilename(source)
	if name != "" {
		return name, nil
	}

	return "", gerrors.NewFileError(source, "detect", "could not detect resource name (use --name flag)", nil)
}

// detectDescription detects the resource description from source file or flag.
// Priority: flag > frontmatter
func detectDescription(source, flag string) (string, error) {
	// Flag takes precedence
	if flag != "" {
		return flag, nil
	}

	// Try frontmatter
	desc, err := extractFrontmatterField(source, "description")
	if err == nil && desc != "" {
		return desc, nil
	}

	// Description is optional - return empty string
	return "", nil
}

// DetectPlatform detects the platform from frontmatter or filename.
// Returns empty string if cannot detect (assumes canonical).
func DetectPlatform(source string) string {
	// Check frontmatter for platform field
	platform, err := extractFrontmatterField(source, "platform")
	if err == nil && platform != "" {
		if IsValidPlatform(platform) {
			return platform
		}
	}

	// Check filename for platform indicators
	lower := strings.ToLower(source)
	if strings.Contains(lower, "opencode") {
		return "opencode"
	}
	if strings.Contains(lower, "claude-code") || strings.Contains(lower, "claudecode") {
		return "claude-code"
	}

	return ""
}

// IsCanonicalFormat checks if the source file is already in canonical format.
func IsCanonicalFormat(source, docType string) bool {
	yamlContent, _, err := extractFrontmatter(source)
	if err != nil || yamlContent == "" {
		return false
	}

	var frontmatter map[string]interface{}
	if err := yaml.Unmarshal([]byte(yamlContent), &frontmatter); err != nil {
		return false
	}

	// Canonical format uses "allowed-tools" as array for command/skill
	// and has "name", "description" fields
	switch docType {
	case "command", "skill":
		if tools, ok := frontmatter["allowed-tools"]; ok {
			if _, isArray := tools.([]interface{}); isArray {
				return true
			}
		}
	case "agent":
		// Agent canonical format has "tools" as array and "name", "description"
		if tools, ok := frontmatter["tools"]; ok {
			if _, isArray := tools.([]interface{}); isArray {
				return true
			}
		}
	case "memory":
		// Memory format is detected differently - just check for paths or content
		if _, hasPaths := frontmatter["paths"]; hasPaths {
			return true
		}
	}

	return false
}

// DetectTypeFromFilename detects document type from filename patterns.
func DetectTypeFromFilename(filepath string) string {
	base := filepath

	// Check agent patterns
	if matched, _ := regexp.MatchString(`agent-.*\.md$`, base); matched {
		return "agent"
	}
	if matched, _ := regexp.MatchString(`.*-agent\.md$`, base); matched {
		return "agent"
	}
	if matched, _ := regexp.MatchString(`agent-.*\.yaml$`, base); matched {
		return "agent"
	}
	if matched, _ := regexp.MatchString(`.*-agent\.yaml$`, base); matched {
		return "agent"
	}

	// Check command patterns
	if matched, _ := regexp.MatchString(`command-.*\.md$`, base); matched {
		return "command"
	}
	if matched, _ := regexp.MatchString(`.*-command\.md$`, base); matched {
		return "command"
	}
	if matched, _ := regexp.MatchString(`command-.*\.yaml$`, base); matched {
		return "command"
	}
	if matched, _ := regexp.MatchString(`.*-command\.yaml$`, base); matched {
		return "command"
	}

	// Check memory patterns
	if matched, _ := regexp.MatchString(`memory-.*\.md$`, base); matched {
		return "memory"
	}
	if matched, _ := regexp.MatchString(`.*-memory\.md$`, base); matched {
		return "memory"
	}
	if matched, _ := regexp.MatchString(`memory-.*\.yaml$`, base); matched {
		return "memory"
	}
	if matched, _ := regexp.MatchString(`.*-memory\.yaml$`, base); matched {
		return "memory"
	}

	// Check skill patterns
	if matched, _ := regexp.MatchString(`skill-.*\.md$`, base); matched {
		return "skill"
	}
	if matched, _ := regexp.MatchString(`.*-skill\.md$`, base); matched {
		return "skill"
	}
	if matched, _ := regexp.MatchString(`skill-.*\.yaml$`, base); matched {
		return "skill"
	}
	if matched, _ := regexp.MatchString(`.*-skill\.yaml$`, base); matched {
		return "skill"
	}

	return ""
}

// addResourceToLibrary adds a resource entry to library.yaml.
func addResourceToLibrary(libraryPath, typ, name, filePath, description string) error {
	yamlPath := filepath.Join(libraryPath, "library.yaml")

	// Read current library.yaml
	content, err := os.ReadFile(yamlPath)
	if err != nil {
		return gerrors.NewFileError(yamlPath, "read", "failed to read library.yaml", err)
	}

	var lib libraryYAML
	if err := yaml.Unmarshal(content, &lib); err != nil {
		return gerrors.NewParseError(yamlPath, "failed to parse library.yaml", err)
	}

	// Initialize maps if nil
	if lib.Resources == nil {
		lib.Resources = make(map[string]map[string]Resource)
	}
	if lib.Resources[typ] == nil {
		lib.Resources[typ] = make(map[string]Resource)
	}

	// Compute relative path from library root
	relPath, err := filepath.Rel(libraryPath, filePath)
	if err != nil {
		return fmt.Errorf("computing relative path: %w", err)
	}

	// Add/update resource entry
	lib.Resources[typ][name] = Resource{
		Path:        relPath,
		Description: description,
	}

	// Marshal back to YAML
	output, err := yaml.Marshal(lib)
	if err != nil {
		return gerrors.NewParseError(yamlPath, "failed to marshal library.yaml", err)
	}

	// Write atomically: write to temp file first, then rename
	tmpPath := yamlPath + ".tmp"
	if err := os.WriteFile(tmpPath, output, 0644); err != nil {
		return gerrors.NewFileError(tmpPath, "write", "failed to write library.yaml", err)
	}
	if err := os.Rename(tmpPath, yamlPath); err != nil {
		return gerrors.NewFileError(yamlPath, "write", "failed to rename temp file", err)
	}

	return nil
}

// extractFrontmatter extracts YAML frontmatter from a markdown file.
func extractFrontmatter(source string) (string, string, error) {
	content, err := os.ReadFile(source) //nolint:gosec // G304: User provides source path, must read it
	if err != nil {
		return "", "", err
	}

	fileContent := string(content)
	lines := strings.Split(fileContent, "\n")
	if len(lines) < 3 {
		return "", fileContent, nil
	}

	if lines[0] != "---" {
		return "", fileContent, nil
	}

	var yamlLines []string
	var bodyLines []string
	foundEnd := false

	for i := 1; i < len(lines); i++ {
		if lines[i] == "---" {
			foundEnd = true
			bodyLines = lines[i+1:]
			break
		}
		yamlLines = append(yamlLines, lines[i])
	}

	if !foundEnd {
		return "", fileContent, nil
	}

	return strings.Join(yamlLines, "\n"), strings.Join(bodyLines, "\n"), nil
}

// extractFrontmatterField extracts a specific field from YAML frontmatter.
func extractFrontmatterField(source, field string) (string, error) {
	yamlContent, _, err := extractFrontmatter(source)
	if err != nil || yamlContent == "" {
		return "", err
	}

	var frontmatter map[string]interface{}
	if err := yaml.Unmarshal([]byte(yamlContent), &frontmatter); err != nil {
		return "", err
	}

	if value, ok := frontmatter[field].(string); ok {
		return value, nil
	}

	return "", fmt.Errorf("field %q not found", field)
}

// extractNameFromFilename extracts a resource name from filename.
// E.g., "agent-reviewer.md" -> "reviewer", "skill-commit.md" -> "commit"
func extractNameFromFilename(source string) string {
	// Get base filename without extension
	base := filepath.Base(source)
	ext := filepath.Ext(base)
	name := strings.TrimSuffix(base, ext)

	// Remove prefix patterns like "agent-", "skill-", "command-", "memory-"
	patterns := []string{
		`^agent[-_]`,
		`^skill[-_]`,
		`^command[-_]`,
		`^memory[-_]`,
		`[-_]agent$`,
		`[-_]skill$`,
		`[-_]command$`,
		`[-_]memory$`,
	}

	for _, pattern := range patterns {
		re := regexp.MustCompile(pattern)
		name = re.ReplaceAllString(name, "")
	}

	return name
}
