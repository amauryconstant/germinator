+func formatInitializeSummary(successCount, failCount int) string {
+	if failCount == 0 {
+		return fmt.Sprintf("Initialized %d resource(s).\n", successCount)
+	}
+	return fmt.Sprintf("Initialized %d resource(s), %d failed.\n", successCount, failCount)
+}


